{
  "name": "@kirtijha1986/flow",
  "version": "0.4.3",
  "private": false,
  "description": "FLOW — Fresh-context Loop for Orchestrated Work. A disciplined five-phase agent loop authored once and generated into Claude Code and GitHub Copilot layouts.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "flow": "bin/install.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "bin/",
    "hooks/",
    ".flow-src/",
    "flow.config.json",
    "docs/flow/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "gen": "node --import tsx scripts/flow-gen.ts",
    "gen:legacy": "node --import tsx scripts/flow-gen.ts --legacy-commands",
    "budget": "node --import tsx scripts/flow-budget.ts",
    "compress": "node --import tsx scripts/flow-compress.ts",
    "metrics": "node --import tsx scripts/flow-metrics.ts",
    "test": "node --import tsx --test \"scripts/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^20.16.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KirtiJha/flow.git"
  },
  "homepage": "https://github.com/KirtiJha/flow#readme",
  "bugs": "https://github.com/KirtiJha/flow/issues",
  "keywords": [
    "claude-code",
    "github-copilot",
    "ai-coding",
    "agent",
    "subagents",
    "workflow",
    "spec-driven",
    "orchestration",
    "verification",
    "token-budget"
  ]
}
